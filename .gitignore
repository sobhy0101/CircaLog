# Never committed — verification only.
tasks/screenshots/
tasks/*.png

# ─── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ─── MCP Configuration ────────────────────────────────────────
# Contains personal access tokens — never commit
.mcp.json

# ─── Misc ─────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.pem
